        for(int i=len1-1;i>=0;i--){
            for(int j=len2-1;j>=0;j--){
                int a=str1.charAt(i)-'0';
                int b=str2.charAt(j)-'0';
                int product=a*b;
                int sum=0;
                sum+=product+res[i+j+1];

                res[i+j+1]=sum%10;
                res[i+j]+=sum/10;
