//14  最长公共前缀
public class l14
{
    //我的想法：先找两个字符串的最长公共子串，再以这个和后面的找
    public String longestCommonPrefix(String[] strs)
    {
        if(strs==null||strs.length==0)return "";
        if(strs.length==1)return strs[0];
        else{
           int len=strs.length;
           String prefix=strs[0];
           for(int i=1;i<len;i++){
               prefix=longestCommonPrefix(prefix,strs[i]);
               if(prefix=="")return prefix;
           }
           return prefix;

        }
    }
    public String longestCommonPrefix(String s1,String s2)
    {
        int lengthh=Math.min(s1.length(),s2.length());
        if(lengthh==0)return "";
        int index=0;
        //String pre;   ——————————————————————————————————————————————————————-这里不用+=。而用index 再用substring函数。这样避免了char string的转换。
        while(index<lengthh&&s1.charAt(index)==s2.charAt(index)){
            index++;
        }
        return s1.substring(0,index);//————————————————————————————————

    }
}
