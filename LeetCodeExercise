//35. 搜索插入位置
public class l35 {
    public int searchInsert(int[] nums, int target) {
//        int len=nums.length;
//        if(len%2==0){//我想用二分查找，但是不知道怎么去递归
//            if(target<nums[len/2-1]){return }
//        }
        int n = nums.length;
        int left=0;
        int right=n-1;
        while(left<=right){
            int mid=left+(right-left)/2;//中间
            if(nums[mid]==target){return mid;}
            else if(nums[mid]>target){
                right=mid-1;
            }
            else{left=mid+1;}---------------------------左右双指针不断更新 如果找到则返回mid else返回left
        }
        return left;


    }

}
