        int len1=a.length()-1;
        int len2=b.length()-1;
        int jinwei=0;
        StringBuilder sb=new StringBuilder();
        //先加两个字符串都有数字的位数
        while(len1>=0&&len2>=0){
            int sum=jinwei;//当前位的起始值为上一位的进位
            sum+=a.charAt(len1--)-'0';//---------------------------字符转数字
            sum+=b.charAt(len2--)-'0';
            jinwei=sum/2;//如果sum为2或3。则进位为1
            sb.append(sum%2);
        }
        while(len1>=0){
            int sum=jinwei+a.charAt(len1--)-'0';
            jinwei=sum/2;
            sb.append(sum%2);
        }
        while(len2>=0){
            int sum=jinwei+b.charAt(len2--)-'0';
            jinwei=sum/2;
            sb.append(sum%2);
        }
        if(jinwei==1){
            sb.append('1');
        }————————————————————————//最高位进位情况
        return sb.reverse().toString();   
    }
}
