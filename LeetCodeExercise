    public boolean isValid(String s){
        Stack<Character> stack=new Stack<>();//注意这里怎样定义栈
        for(int i=0;i<s.length();i++){
            char c=s.charAt(i);
            if(c=='(')stack.push(')');
            else if(c=='{')stack.push('}');
            else if(c=='[')stack.push(']');
            else{
                if(stack.isEmpty()||stack.pop()!=c)return false;
            }
        }
        return stack.isEmpty();//栈空则匹配成功

    }
