//二分查找（前提：必须有序）
package CommonAlgorithm;

import java.util.Scanner;

public class binarySearch {
    public static void main(String[] args) {
        int[]arr={7,23,79,81,127,147};
        System.out.println(binarySearc(arr,127));
    }
    public static int binarySearc(int[] arr,int num){
        int min=0;
        int max=arr.length-1;
        while(true){
            if(min>max){
                return -1;
            }
            int mid=(min+max)/2;
            if(arr[mid]==num){
                return mid;
            }
            else if(arr[mid]<num){
                min=mid+1;
            }
            else{
                max=mid-1;
            }

        }

    }
}
