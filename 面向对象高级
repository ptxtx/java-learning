//super关键字
package oop.extendstest;

public class test2 {
    public static void main(String[] args){
    Zi zi=new Zi();
    zi.show();
}
static class Fu{
    String name="Fu";
}
static class Zi extends Fu{
    String name="Zi";
    
    public void show(){
        String name="Zishow";
        System.out.println(name);
        System.out.println(this.name);
        System.out.println(super.name);
    }
}

}
