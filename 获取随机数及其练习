//这是如何获得随机数 的代码
import java.util.Random;
public class exercise {
    public static void main(String[] args) {
//获取随机数：random
        Random r=new Random();
        int a=r.nextInt(15)+7;//7-21(左闭右开)
        System.out.println("随机数是："+a);

       //任意数到任意数的随机数秘诀：
       //1.让这个数的头尾都减去一个值，让这个范围从0开始
       //2.尾巴+1为括号内的值
       //3.括号外加上第二步减去的值
}
