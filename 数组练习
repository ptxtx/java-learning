        Random random = new Random();
        int[] arr = new int[10];
        int count = 0;// 记录当前已经成功存入了几个不重复的数字------------------------------这一步很重要

        while (count < 10) {
            int num = random.nextInt(100) + 1; // 生成随机数
            boolean isDuplicate = false; // 标记是否重复
            
            // 遍历目前已经存入的数字，检查是否重复
            for (int i = 0; i < count; i++) {
                if (arr[i] == num) {
                    isDuplicate = true;
                    break; // 发现重复，停止检查
                }
            }
            
            // 如果不重复，则存入数组，并将计数器加1
            if (!isDuplicate) {
                arr[count] = num;
                count++;
            }
        }

        // 打印结果
        for (int i = 0; i < 10; i++) {
            System.out.println(arr[i]);
        }
