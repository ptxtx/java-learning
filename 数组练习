————————————————————————————————————————//快慢指针法
需求：给定义一个递增有序数组，去除其中重复元素
慢指针：存入的位置；快指针：找不重复的数据；指向数据相等->舍弃快指针位置的数据；不相等->快指针的数据存入慢指针位置（慢指针先自增 再存入）
int arr[]={1,2,2,2,2,2,3,3,3,3};
//定义两个变量（类似于c中的指针）
int slow=0;
int fast=1;
while(fast<arr.length){//快指针遍历完则结束
//判断两个指针指向数据是否相同
if(arr[slow]==arr[fast]){
    fast++;//相同则快指针继续往后走
}
else{slow++;
    arr[slow]=arr[fast];
    fast++;
}
