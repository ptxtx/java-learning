//TreeMapExercise1（在需要排序输出的时候才用TreeMap，不然用HashMap就行）
import java.util.TreeMap;
import java.util.function.BiConsumer;
import java.util.function.Consumer;

public class TreeMapExercise1 {
    public static void main(String[] args) {
        /*
        统计字符串中每一个字符出现的次数 并按一定格式输出
         */
        String str="aababcabcdabcde";
        TreeMap<Character,Integer> map=new TreeMap<>();
        //那如果我想知道这个字符串中有哪些字母怎么办？
        for(int i=0;i<str.length();i++){
            char c=str.charAt(i);
            if(!map.containsKey(c)){
                map.put(c,1);
            }
            else{
                map.put(c,map.get(c)+1);
            }
        }
        System.out.println(map);
        StringBuilder sb=new StringBuilder();

        //如果我想自定义输出格式
        map.forEach(new BiConsumer<Character, Integer>() {
            @Override
            public void accept(Character character, Integer integer) {
                sb.append(character).append("(").append(integer).append(")");
            }
        });
        System.out.println(sb);

    }
}
