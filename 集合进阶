//可变参数
package MyMap;

public class ArgsDemo1 {
    public static void main(String[] args) {
        int sum=getSum(1,2,3,4,5);
        System.out.println(sum);
    }
    public static int getSum(int...arg){
        //可变参数，底层就是一个数组，Java会帮我们创建
        int sum=0;
        for(int i:arg){
            sum+=i;
        }
        return sum;
    }
}
