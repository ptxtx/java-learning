//Map三种遍历方式
package MyMap;

import java.util.HashMap;
import java.util.Iterator;
import java.util.Map;
import java.util.Set;

public class MapDemo2 {
    public static void main(String[] args) {
        Map<String,String> m=new HashMap<>();//泛型也是两个（K V）

        m.put("郭靖","王蓉");
        m.put("a","b");
        m.put("c","d");

        //通过键找值
        Set<String> keys = m.keySet();//获取所有的键，把这些键放到一个单列集合中
        for(String key:keys){
            //System.out.println(key);
            //利用map集合中的键获取对应的值 get
            String value=m.get(key);
            System.out.println(value);
        }

        //通过键值对方式
        //通过一个方法获取所有的键值对对象，返回一个Set集合
        Set<Map.Entry<String, String>> entries = m.entrySet();//set里面装entry对象//Entry是Map的一个内部接口 所以是Map.Entry
        for(Map.Entry<String,String> entry:entries){
            String key=entry.getKey();
            String value=entry.getValue();
            System.out.println(key+"="+value);
        }
            //迭代器遍历
        Iterator<Map.Entry<String, String>> iterator = entries.iterator();
        while(iterator.hasNext()){
            Map.Entry<String, String> entry=iterator.next();
            String key=entry.getKey();
            String value=entry.getValue();
            System.out.println(key+"="+value);
        }

        //通过Lambda表达式
        //底层：利用第二种方式进行遍历，依次得到每一个键和值
        //再调用accept方法
        m.forEach((K,V)->System.out.println(K+"="+V));


    }
}
