//1.static关键字
package oop.staticc;
public class Student {
String name;
int age;
static String teacherName;

}

public class test {

    public static void main(String[] args) {
        Student stu1=new Student();
        stu1.name="张三";
        stu1.age=20;
        Student.teacherName="李老师";//类名调用静态成员 表示Student这个类所有对象的techername都是李老师
        Student stu2=new Student();
        stu2.name="李四";
        stu2.age=22;
        stu2.teacherName="王老师";//其中一个人想换老师 会导致所有对象的老师都改变

        System.out.println(stu1.name+","+stu1.age+","+stu1.teacherName);
        System.out.println(stu2.name+","+stu2.age+","+stu2.teacherName);
    }
}
