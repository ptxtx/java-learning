public class Test4 {
    public static void main(String[] args) {
        /*
        定义两个字符串，记录为非负整数，求他们的和
        注意：需要数据过大，超出int取值范围的情况
         */
        String str1="9999";
        String str2="99999";

        int len=str1.length()>=str2.length()?str1.length():str2.length();
        int arr1[]=copyDate(str1,len);
        int arr2[]=copyDate(str2,len);

        int arr3[]=new int[len+1];//存储最终结果
        int jinwei=0;
        for(int i=len-1;i>=0;i--){
            int temp=arr1[i]+arr2[i]+jinwei;
            arr3[i+1]=temp%10;//i+1!!!!!!!  因为第三个数组的长度长1
            jinwei=temp/10;

        }
        arr3[0]=jinwei;
       StringBuilder builder=new StringBuilder();

           if(jinwei==0){}
           else{builder.append(arr3[0]);}
        for(int i=1;i<arr3.length;i++){
            builder.append(arr3[i]);
       }
       System.out.println(builder.toString());

    }
    public static int[] copyDate(String str,int len){
        int [] arr=new int[len];
        int lenn=arr.length-1;
        //——————————！！！把字符串中的数据放入数组中要倒着遍历（不然就是最高位与最低位做加法了）
        for(int i=str.length()-1;i>=0;i--){
            char ch=str.charAt(i);
            arr[lenn--]=ch-'0';

        }
        return arr;
    }
}
