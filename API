public class Test1 {
    public static void main(String[] args) {
        String qq="123456";
        //boolean b = checkQQ(qq);
       // System.out.println(b);



        //————————————————正则表达式体验
        boolean matches = qq.matches("[1-9]\\d{5,19}");
        System.out.println(matches);
    }
    public static boolean checkQQ(String qq){
        //核心思想：先把异常数据过滤，剩下的就是满足条件的数据
        int len=qq.length();
        if(len<6||len>20){
            return false;
        }
        if(qq.charAt(0)=='0'){
            return false;
        }
        for(int i=1;i<len;i++){
            char c=qq.charAt(i);
            if(c<'0'||c>'9'){
                return false;
            }
        }
        return true;
    }
}
