//4.经典算法题之接雨水
import java.util.Random;
public class test {
    public static void main(String[] args) {
     //接雨水是在柱子与柱子间残留的水量（动态规划思想DP)
     //先给最右边加一堵无限高的墙 看哪些雨水能留下 再给最左边加一堵墙 再看哪些雨水能留下 最后能留下的雨水取交集就是最终能留下的雨水
     int height[]={0,1,0,2,1,0,1,3,2,1,2,1};
     //1.从左往右看
     int leftmax[]=new int[height.length];
     //1.1定义第三方变量temp记录当前最高的墙
     int temp=height[0];
     //1.2从左往右遍历数组
     for(int i=0;i<height.length;i++){
        if(temp>height[i]){leftmax[i]=temp;}
        else{leftmax[i]=height[i];temp=height[i];}

     }
    //2.从右往左
    int rightmax[]=new int[height.length];
    temp=height[height.length-1];
    for(int i=height.length-1;i>=0;i--){
        if(temp>height[i]){rightmax[i]=temp;}
        else{rightmax[i]=height[i];temp=height[i];}
    }
    //3.取交集
    int min[]=new int[height.length];
    for(int i=0;i<height.length;i++){
        min[i]=Math.min(leftmax[i],rightmax[i]);
    }
    //4.计算（减去柱子）
    int cur[]=new int[height.length];
    for(int i=0;i<height.length;i++){
        cur[i]=min[i]-height[i];
    }
    int sum=0;
    for(int i=0;i<cur.length;i++){
        sum+=cur[i];}
    System.out.println(sum);
    } 
}
